SECRET_KEY=change-this-to-a-long-random-string

# Supabase Postgres connection string.
# Get this from: Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
# (use the "Connection pooling" URI for Railway, port 6543, not the direct 5432 one)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:6543/postgres

# Optional — email (verification links / password resets are logged to the
# console if these are left blank, so the app still works for local testing)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=no-reply@oja.ng

# Optional — payment gateways (card checkout runs in demo mode until these are set)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=

# Railway sets RAILWAY_ENVIRONMENT automatically on deploy — leave unset locally.
# FLASK_ENV is a manual override for testing production-like settings locally.
FLASK_ENV=development
